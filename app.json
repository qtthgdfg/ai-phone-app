{
  "expo": {
    "name": "AI Assistant",
    "slug": "ai-phone-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "aiapp",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.aiassistant",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera used to analyze images with AI",
        "NSMicrophoneUsageDescription": "Microphone for voice input",
        "NSPhotoLibraryUsageDescription": "Access photos for AI analysis",
        "NSPhotoLibraryAddUsageDescription": "Save AI-generated images"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.yourname.aiassistant",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.VIBRATE"
      ],
      "blockedPermissions": []
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        { "cameraPermission": "Allow AI Assistant to access your camera." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "Allow AI Assistant to access your photos." }
      ],
      "expo-document-picker",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow AI Assistant to access your photos.",
          "savePhotosPermission": "Allow AI Assistant to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": { "typedRoutes": true }
  }
}
